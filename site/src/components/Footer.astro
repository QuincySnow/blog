---
const today = new Date();
---

<footer>
	&copy; {today.getFullYear()} QuincySnow. <span data-i18n="footer.copyright">All rights reserved.</span>
</footer>
<style is:global>
	footer {
		flex-shrink: 0;
		margin: 0;
		padding: 0.25em 1em;
		min-height: 2.5rem;
		font-size: 0.8125rem;
		line-height: 1.3;
		background: linear-gradient(var(--bg-gradient)) no-repeat;
		background-color: rgb(var(--bg));
		color: rgb(var(--text));
		text-align: center;
		transition: background-color var(--duration-normal) var(--ease-out), color var(--duration-fast) var(--ease-out);
	}
</style>
